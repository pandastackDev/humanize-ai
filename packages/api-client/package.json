{
  "name": "@humanize/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "openapi-ts",
    "generate:staging": "OPENAPI_URL=https://humanize-python.vercel.app/openapi.json openapi-ts",
    "lint-ci": "oxlint --type-aware && eslint",
    "lint": "oxlint --type-aware --fix --fix-suggestions --fix-dangerously && eslint --fix",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf src/client"
  },
  "dependencies": {
    "@tanstack/react-query": "5.90.10"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.5.7",
    "@hey-api/client-next": "^0.5.1",
    "@hey-api/openapi-ts": "^0.87.2",
    "@humanize/configs": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "oxlint": "^1.29.0",
    "oxlint-tsgolint": "^0.8.0",
    "typescript": "5.9.2"
  }
}
