# Vercel Ignore File
# Files and directories to exclude from Vercel deployment

# Development files
node_modules
.git
.github
.vscode
.idea

# Build artifacts not needed
apps/expo
packages/app/node_modules

# Backend development files
backend/dist
backend/__pycache__
backend/**/__pycache__
backend/.pytest_cache
backend/tests

# Documentation (optional - remove if you want to deploy docs)
*.md
!README.md

# Python cache
__pycache__
*.py[cod]
*$py.class
*.so
.Python

# Environment files (these should be set in Vercel dashboard)
.env
.env.local
.env*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage
.nyc_output

# Misc
.DS_Store
*.pem
.turbo

