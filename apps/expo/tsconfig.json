{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./*"],
      "app/*": ["../../packages/app/*"]
    },
    "noEmit": true,
    "incremental": true,
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "global.d.ts",
    "expo-env.d.ts",
    "uniwind-types.d.ts"
  ]
}
