{
  // https://oxc.rs/docs/guide/usage/linter/config-file-reference.html
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist/*",
    "**/*.gen.ts",
    "**/.expo",
    "**/node_modules",
    "babel.config.js",
    "metro.config.js",
    "eslint.config.js"
  ],
  // https://oxc.rs/docs/guide/usage/linter/plugins.html
  "plugins": [
    "unicorn",
    "typescript",
    "oxc",
    "react",
    "react-perf",
    "jsx-a11y",
    "import",
    "jsdoc",
    "node",
    "promise",
    "vitest",
    "nextjs"
  ],
  "categories": {
    "correctness": "off", // Rules to lint code that is definitely wrong or useless
    "suspicious": "off", // Rules to lint code that is likely to be wrong or useless
    "pedantic": "off", // Rules which are extra strict or might have false positives
    "perf": "off", // Rules that aim to improve the performance of code
    "style": "off", // Rules that help maintain a consistent style or enforce idiomatic syntax
    "restriction": "off", // Rules that ban specific patterns, syntax, or features and should be enabled on a case-by-case basis
    "nursery": "off" // Rules that are in development, may change significantly, or contain false positives
  },
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": null,
      "components": {},
      "attributes": {}
    },
    "next": {
      "rootDir": []
    },
    "react": {
      "formComponents": [],
      "linkComponents": []
    },
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    },
    "vitest": {
      "typecheck": false
    }
  },
  "env": {
    "builtin": true
    // "browser": true
  },
  "globals": {
    // "foo": "readonly"
  },
  // https://oxc.rs/docs/guide/usage/linter/rules.html
  "rules": {
    // ESLint core rules
    // "no-unused-vars": [
    //   "error",
    //   {
    //     "args": "none",
    //     "caughtErrors": "none",
    //     "varsIgnorePattern": "^h|React|createElement|Fragment$"
    //   }
    // ],
    "no-unused-vars": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "no-ternary": "off",
    "max-lines-per-function": "off",
    "no-magic-numbers": "off",
    "func-style": "off",
    "max-lines": "off",
    "no-alert": "off",
    "no-negated-condition": "off",
    "no-undef": "off",
    "no-undefined": "off",
    "prefer-destructuring": "off",
    "id-length": "off",
    "no-warning-comments": "off",
    "no-console": "off",

    // Import plugin rules
    "import/max-dependencies": "off",
    "import/no-default-export": "off",
    "import/no-namespace": "off",
    "import/no-named-export": "off",
    "import/exports-last": "off",
    "import/group-exports": "off",
    "import/no-unassigned-import": "off",
    "import/consistent-type-specifier-style": "off",
    "import/prefer-default-export": "off",
    "import/namespace": "off",

    // OXC rules
    "oxc/no-async-await": "off",
    "oxc/no-optional-chaining": "off",
    "oxc/no-rest-spread-properties": "off",
    "oxc/no-barrel-file": "off",

    // React plugin rules
    "react/jsx-filename-extension": "off",
    "react/react-in-jsx-scope": "off",
    "react/no-unescaped-entities": "off",
    "react/only-export-components": "off",
    "react/jsx-no-useless-fragment": "off",

    // React perf rules
    "react-perf/jsx-no-new-function-as-prop": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react-perf/jsx-no-jsx-as-prop": "off",
    "react-perf/jsx-no-new-array-as-prop": "off",

    // JSX A11y rules
    "jsx-a11y/prefer-tag-over-role": "off",

    // TypeScript ESLint rules
    "typescript/ban-ts-comment": [
      "error",
      {
        "ts-expect-error": "allow-with-description",
        "ts-ignore": true,
        "ts-nocheck": true,
        "ts-check": false,
        "minimumDescriptionLength": 3
      }
    ],
    "typescript/explicit-module-boundary-types": "off",
    "typescript/explicit-function-return-type": "off",
    "typescript/array-type": "off",
    "typescript/consistent-type-definitions": "off",
    "typescript/no-confusing-void-expression": "off",
    "typescript/no-duplicate-type-constituents": "off",
    "typescript/no-floating-promises": "off",
    "typescript/strict-boolean-expressions": "off",
    "typescript/no-misused-promises": "off",
    "typescript/no-unsafe-argument": "off",
    "typescript/no-unsafe-assignment": "off",
    "typescript/no-unsafe-call": "off",
    "typescript/no-unsafe-enum-comparison": "off",
    "typescript/no-unsafe-member-access": "off",
    "typescript/no-unsafe-return": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/promise-function-async": "off",
    "typescript/restrict-template-expressions": "off",
    "typescript/unbound-method": "off",

    // Unicorn rules
    "unicorn/no-null": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/require-module-specifiers": "off",

    // JSDoc plugin rules
    "jsdoc/require-param": "off",
    "jsdoc/require-returns": "off",

    // Promise plugin rules
    "promise/avoid-new": "off",

    // Node plugin rules
    "node/no-process-env": "off"
  },
  "overrides": [
    {
      "files": ["scripts/*.js"],
      "rules": {
        // Allow console.* calls in scripts
        "no-console": "off"
      }
    }
    // {
    //   // Enable TypeScript-specific rules for TypeScript files
    //   "files": ["**/*.{ts,tsx}"],
    //   "plugins": ["typescript"],
    //   "rules": {
    //     "typescript/no-explicit-any": "error"
    //   }
    // },
    // {
    //   // Enable Jest rules for tests
    //   "files": ["**/test/**"],
    //   "plugins": ["jest"],
    //   "env": {
    //     "jest": true
    //   },
    //   "rules": {
    //     "jest/no-disabled-tests": "off"
    //   }
    // }
  ]
}
