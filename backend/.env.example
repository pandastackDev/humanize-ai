# Environment Configuration
ENVIRONMENT=development

# OpenRouter Configuration (PREFERRED - unified interface for all LLMs)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here
OPENROUTER_REFERRER_URL=http://localhost:8000  # Update with production URL (e.g., https://humanize-python.vercel.app)

# OpenRouter Model Identifiers
OPENROUTER_MODEL_GPT4=openai/gpt-4-turbo  # or "openai/gpt-4o"
OPENROUTER_MODEL_CLAUDE=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_EMBEDDING=openai/text-embedding-3-large

# OpenAI Configuration (FALLBACK - if OpenRouter not available)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model Configuration
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_LLM_MODEL=gpt-4-turbo-preview

# Anthropic Configuration (FALLBACK - if OpenRouter not available)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Anthropic Model Configuration
ANTHROPIC_LLM_MODEL=claude-3-5-sonnet-20241022

# FastText Configuration (OPTIONAL - for language detection)
# Download model from: https://fasttext.cc/docs/en/language-identification.html
FASTTEXT_MODEL_PATH=models/lid.176.bin

# Validation Thresholds
SEMANTIC_SIMILARITY_THRESHOLD=0.92
STYLE_SIMILARITY_THRESHOLD=0.90

# Chunking Configuration
MAX_CHUNK_TOKENS=1000
MIN_CHUNK_TOKENS=500
