{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "STRIPE_API_KEY",
        "WORKOS_API_KEY",
        "WORKOS_CLIENT_ID",
        "WORKOS_COOKIE_PASSWORD",
        "NEXT_PUBLIC_WORKOS_REDIRECT_URI",
        "NEXT_PUBLIC_BASE_URL",
        "CONVEX_DEPLOYMENT",
        "NEXT_PUBLIC_CONVEX_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["OPENAPI_URL", "NEXT_PUBLIC_PYTHON_API_URL"]
    },
    "lint-ci": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
