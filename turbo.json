{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "STRIPE_API_KEY",
        "WORKOS_API_KEY",
        "WORKOS_CLIENT_ID",
        "WORKOS_COOKIE_PASSWORD",
        "NEXT_PUBLIC_WORKOS_REDIRECT_URI",
        "NEXT_PUBLIC_BASE_URL",
        "CONVEX_DEPLOYMENT",
        "NEXT_PUBLIC_CONVEX_URL"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json"],
      "outputs": ["**/.tsbuildinfo", "**/tsconfig.tsbuildinfo"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", ".oxlintrc.json", "eslint.config.js"],
      "outputs": [],
      "cache": true
    },
    "lint-ci": {
      "dependsOn": ["^lint-ci"],
      "inputs": ["$TURBO_DEFAULT$", ".oxlintrc.json", "eslint.config.js"],
      "outputs": [],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
