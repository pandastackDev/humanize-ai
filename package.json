{
  "name": "@humanize/monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "app": "pnpm -F app",
    "api-client": "pnpm -F @humanize/api-client",
    "configs": "pnpm -F @humanize/configs",
    "ui": "pnpm -F @humanize/ui",
    "next": "pnpm -F @humanize/next",
    "expo": "pnpm -F @humanize/expo",
    "web": "pnpm next dev",
    "native": "pnpm expo dev",
    "convex": "pnpm next dev:convex",
    "python": "cd backend && uv run uvicorn src.index:app --reload --host 0.0.0.0 --port 8000",
    "check": "./check.sh",
    "check-types": "turbo check-types",
    "bump-deps": "pnpm up -iLr",
    "bump-next": "cd apps/next && pnpx @next/codemod@canary upgrade latest",
    "bump-biome": "pnpm update @biomejs/biome --latest && biome migrate --write",
    "clean": "turbo clean && rm -rf .turbo",
    "reinstall": "rm -rf node_modules **/node_modules pnpm-lock.yaml **/pnpm-lock.yaml && pnpm install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "convex": "^1.29.3",
    "turbo": "^2.6.1"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.4",
      "@types/react-dom": "19.2.3"
    }
  }
}
