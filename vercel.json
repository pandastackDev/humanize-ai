{
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.next,.git,node_modules,backend/node_modules,apps/next/node_modules}/**"
    }
  },
  "buildCommand": "SKIP_ENV_VALIDATION=true pnpm --filter @humanize/next build",
  "outputDirectory": "apps/next/.next",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/index.py"
    }
  ]
}
