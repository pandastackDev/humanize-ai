{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd apps/next && pnpm build",
  "outputDirectory": "apps/next/.next",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "backend/src/api/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api2/(.*)",
      "dest": "backend/src/api/main.py"
    }
  ]
}
